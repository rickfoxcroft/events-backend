{
  "name": "backend",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "appPort": [8787],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "typespec.typespec-vscode",
        "jdx.mise-vscode"
      ],
      "settings": {
        "rust-analyzer.checkOnSave.command": "clippy",
        "mise.enabled": true
      }
    }
  },
  "forwardPorts": [8787],
  "postCreateCommand": "mise install"
}
