{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "codegen:zod": "openapi-zod-client ../../tsp-output/openapi.yaml -o src/types/api-zod.ts -t zod-template.hbs && prettier --write src/types/api-zod.ts",
    "codegen:types": "openapi-typescript ../../tsp-output/openapi.yaml -o src/types/api.d.ts && prettier --write src/types/api.d.ts && npm run codegen:zod",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "@astrojs/preact": "^5.1.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.2",
    "preact": "^10.29.1",
    "tailwindcss": "^4.3.0",
    "wrangler": "^4.90.1",
    "zod": "^3.24.2"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "openapi-typescript": "^7.13.0",
    "openapi-zod-client": "^1.18.3",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  }
}
