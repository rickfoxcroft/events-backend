---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      <!-- Column 1: Branding -->
      <div class="flex flex-col gap-6">
        <a href="/" class="group flex items-center gap-2">
          <div
            class="bg-primary flex h-8 w-8 transform items-center justify-center rounded-lg transition-transform duration-300 group-hover:rotate-6"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-map-pin"
              ><path
                d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
          </div>
          <span class="text-navy text-xl font-bold tracking-tight"
            >EventApp</span
          >
        </a>
        <p class="max-w-xs text-sm leading-relaxed text-gray-500">
          Discover and book the most inspiring spaces for your next event. From
          lofts to ballrooms, we've got you covered.
        </p>
        <div class="flex gap-4">
          <!-- Mock Social Icons -->
          <a
            href="#"
            class="hover:text-primary hover:border-primary/30 flex h-8 w-8 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-400 transition-all"
          >
            <span class="sr-only">Twitter</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-twitter"
              ><path
                d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"
              ></path></svg
            >
          </a>
          <a
            href="#"
            class="hover:text-primary hover:border-primary/30 flex h-8 w-8 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-400 transition-all"
          >
            <span class="sr-only">Instagram</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-instagram"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg
            >
          </a>
        </div>
      </div>

      <!-- Column 2: Explore -->
      <div>
        <h4 class="text-navy mb-6 text-xs font-bold tracking-widest uppercase">
          Explore
        </h4>
        <ul class="flex flex-col gap-4 text-sm text-gray-500">
          <li>
            <a href="/venues" class="hover:text-primary transition-colors"
              >Search Venues</a
            >
          </li>
          <li>
            <a href="/categories" class="hover:text-primary transition-colors"
              >Categories</a
            >
          </li>
          <li>
            <a href="/featured" class="hover:text-primary transition-colors"
              >Featured Spaces</a
            >
          </li>
          <li>
            <a href="/cities" class="hover:text-primary transition-colors"
              >Popular Cities</a
            >
          </li>
        </ul>
      </div>

      <!-- Column 3: Host -->
      <div>
        <h4 class="text-navy mb-6 text-xs font-bold tracking-widest uppercase">
          Hosting
        </h4>
        <ul class="flex flex-col gap-4 text-sm text-gray-500">
          <li>
            <a href="/host" class="hover:text-primary transition-colors"
              >List Your Space</a
            >
          </li>
          <li>
            <a href="/how-it-works" class="hover:text-primary transition-colors"
              >How it Works</a
            >
          </li>
          <li>
            <a href="/insurance" class="hover:text-primary transition-colors"
              >Host Insurance</a
            >
          </li>
          <li>
            <a href="/resources" class="hover:text-primary transition-colors"
              >Resources</a
            >
          </li>
        </ul>
      </div>

      <!-- Column 4: Support -->
      <div>
        <h4 class="text-navy mb-6 text-xs font-bold tracking-widest uppercase">
          Support
        </h4>
        <ul class="flex flex-col gap-4 text-sm text-gray-500">
          <li>
            <a href="/help" class="hover:text-primary transition-colors"
              >Help Center</a
            >
          </li>
          <li>
            <a href="/contact" class="hover:text-primary transition-colors"
              >Contact Us</a
            >
          </li>
          <li>
            <a href="/terms" class="hover:text-primary transition-colors"
              >Terms of Service</a
            >
          </li>
          <li>
            <a href="/privacy" class="hover:text-primary transition-colors"
              >Privacy Policy</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-8 md:flex-row"
    >
      <p class="text-xs text-gray-400">
        &copy; {currentYear} EventApp Inc. Built with "Open Design" principles.
      </p>
      <div class="flex gap-6">
        <span class="text-xs text-gray-400">Secure Payments</span>
        <span class="text-xs text-gray-400">Verified Venues</span>
      </div>
    </div>
  </div>
</footer>
