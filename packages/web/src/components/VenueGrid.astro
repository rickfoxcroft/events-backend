---
import VenueCard from './VenueCard.astro';
import { api } from '../lib/api';
import { schemas } from '../types/api-zod';
import type { VenueDTO } from '../types/venue';

const { data, error, response } = await api.GET('/venues');

// TODO: Implement more robust error handling (e.g. exponential backoff, circuit breaking)
// and provide a better user experience (e.g. error states, retry button)
if (!response.ok || error) {
  throw new Error(`Failed to fetch venues: ${response.statusText}`);
}

let venues: VenueDTO[] = [];
try {
  // Runtime validation using auto-generated Zod schema
  venues = schemas.VenueDTO.array().parse(data);
} catch (error) {
  console.error('API Validation Error:', error);
  if (error instanceof Error) {
    throw new Error(`Failed to validate API response: ${error.message}`);
  }
}
---

<section id="venues" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="mb-12 flex flex-col justify-between gap-6 md:flex-row md:items-end"
    >
      <div class="max-w-2xl">
        <h2 class="text-navy text-3xl font-bold tracking-tight md:text-4xl">
          Explore Popular Venues
        </h2>
        <p class="mt-4 leading-relaxed text-gray-600">
          From historic ballrooms to modern industrial lofts, find a space that
          inspires your guests and fits your budget.
        </p>
      </div>

      <a
        href="/venues"
        class="text-primary hover:text-navy group inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase transition-colors"
      >
        View All Venues
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-arrow-right transition-transform group-hover:translate-x-1"
          ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
        >
      </a>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {venues.map((venue) => <VenueCard venue={venue} />)}
    </div>

    <div class="mt-16 text-center">
      <div
        class="inline-flex items-center gap-3 rounded-2xl border border-gray-100 bg-gray-50 px-6 py-3"
      >
        <span class="bg-primary flex h-2 w-2 animate-pulse rounded-full"></span>
        <span class="text-sm font-medium text-gray-600">
          New venues added every week in your area.
        </span>
      </div>
    </div>
  </div>
</section>
