# Bruno Environment Variables
# The URL of your deployed Cloudflare Worker
PROD_BASE_URL=https://event-app-backend.<your-subdomain>.workers.dev

# Cloudflare Configuration (Optional: for local Wrangler usage)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token

# Cloudflare Images
CF_ACCOUNT_ID=your-account-id
CF_IMAGES_API_TOKEN=your-api-token
CF_IMAGES_ACCOUNT_HASH=your-account-hash
